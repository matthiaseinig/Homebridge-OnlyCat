{
  "displayName": "OnlyCat",
  "name": "homebridge-onlycat",
  "version": "0.1.0",
  "description": "Homebridge plugin for the OnlyCat smart cat flap — exposes the flap as a HomeKit camera with HomeKit Secure Video, per-cat presence sensors, and door-policy controls.",
  "license": "MIT",
  "author": "Matthias Einig",
  "homepage": "https://github.com/matthiaseinig/OnlyCatHomebridge#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/matthiaseinig/OnlyCatHomebridge.git"
  },
  "bugs": {
    "url": "https://github.com/matthiaseinig/OnlyCatHomebridge/issues"
  },
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": "^18.20.0 || ^20.15.0 || ^22.0.0",
    "homebridge": "^1.8.0 || ^2.0.0-beta.0"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "lint": "eslint src",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "dev": "npm run build && homebridge -U ./dev -P .",
    "preflight": "npm run lint && npm run build && npm run test:coverage && npm audit --omit=dev --audit-level=high",
    "prepublishOnly": "npm run preflight"
  },
  "keywords": [
    "homebridge-plugin",
    "homekit",
    "onlycat",
    "cat-flap",
    "hksv",
    "camera"
  ],
  "devDependencies": {
    "@types/node": "^22.7.0",
    "@typescript-eslint/eslint-plugin": "^8.8.0",
    "@typescript-eslint/parser": "^8.8.0",
    "@vitest/coverage-v8": "^2.1.2",
    "eslint": "^9.12.0",
    "homebridge": "^1.8.4",
    "prettier": "^3.3.3",
    "typescript": "^5.6.2",
    "vitest": "^2.1.2"
  },
  "dependencies": {
    "socket.io-client": "^4.8.3"
  }
}
